# Update these with your Supabase details from your local `supabase start` output
# (Studio at http://127.0.0.1:54323 → Project Settings → API) or from
# https://app.supabase.com/project/_/settings/api on Cloud.
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only. Used in trusted server code (admin actions, scripts, tests).
# NEVER prefix with NEXT_PUBLIC_ and NEVER import in a Client Component.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
