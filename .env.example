# Supabase (existing — fill these in for local dev)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Lettermint — transactional email for sign-up confirmation (PLAN.md §4.4)
# Real token lives in .env.local (gitignored). Lettermint dashboard:
# https://lettermint.com — domain practicaldatajobs.com is configured there.
LETTERMINT_API_TOKEN=
LETTERMINT_SENDER_DOMAIN=practicaldatajobs.com

# Voyage AI — embedding API for CV/job semantic search (PLAN.md §9.5)
# Sign up at https://www.voyageai.com — voyage-3 model, 1024-dim embeddings.
VOYAGE_API_KEY=

# Site URL — used for email redirect links (Supabase confirmation, password reset).
# Set to your Vercel domain in production, http://localhost:3000 locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
